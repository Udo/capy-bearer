function RENDER {
    var action := request_get("action")
    if action == "token" {
        print(csrf_token("capy-csrf", "token"))
    } else {
        if action == "valid" {
            print(csrf_valid(request_get("submitted"), "capy-csrf", "token"))
        } else {
            csrf_rotate("capy-csrf", "token")
            print(csrf_token("capy-csrf", "token"))
        }
    }
}
