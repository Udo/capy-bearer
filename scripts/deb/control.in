Package: @PACKAGE_NAME@
Version: @VERSION@
Section: web
Priority: optional
Architecture: @ARCH@
Depends: bash, python3, curl, systemd, libpcre2-8-0, zlib1g, libssl3, libstdc++6, libgcc-s1, libmariadb3 | libmysqlclient21 | libmysqlclient24
